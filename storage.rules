rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // This app does NOT use Firebase Storage (no photo/file uploads).
    // Storage is intentionally left unused to avoid requiring the Blaze plan.
    // Deny everything so that, if Storage is ever enabled by accident, no data
    // is exposed. Re-open specific paths here if file uploads are added later.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
