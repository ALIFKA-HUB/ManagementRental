rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && userData().role == 'admin'; }
    // The driverId linked to the signed-in user (null if unlinked / not a driver).
    function myDriverId() { return isSignedIn() ? userData().driverId : null; }

    // Users: own doc, or admin can read/manage all
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isAdmin();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Vehicles — authenticated read, admin write
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Drivers — authenticated read, admin write
    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Bookings — admin full access; an operator may read ONLY the bookings
    // assigned to their own driver record (query must filter by driverId).
    // No client deletes.
    match /bookings/{bookingId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.driverId == myDriverId());
      allow create, update: if isAdmin();
      allow delete: if false;

      // Activity log: admin-only writes so operators cannot forge audit entries.
      match /logs/{logId} {
        allow read: if isAdmin() ||
          (isSignedIn() &&
           get(/databases/$(database)/documents/bookings/$(bookingId)).data.driverId == myDriverId());
        allow create: if isAdmin();
        allow update, delete: if false;
      }
    }

    // Customers hold PII (name/phone) — admin only.
    match /customers/{customerId} {
      allow read, write: if isAdmin();
    }

    // Settings (rental policy: buffer time, etc.) — authenticated read, admin write
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Sementara koleksi lain ditutup — akan dibuka per phase
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
